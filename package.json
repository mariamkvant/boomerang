{
  "name": "boomerang",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:server": "ts-node server/index.ts",
    "dev:client": "cd client && npm run dev",
    "build:client": "cd client && npm install && npm run build",
    "build": "npm run build:client && npx tsc -p tsconfig.json",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0",
    "stripe": "^21.0.1",
    "web-push": "^3.6.7",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  }
}
