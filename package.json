{
  "name": "boomerang",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:server": "ts-node server/index.ts",
    "dev:client": "cd client && npm run dev",
    "build:client": "cd client && npm install && npm run build",
    "build": "npm run build:client && npx tsc -p tsconfig.json",
    "start": "node dist/server/index.js",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/pg": "^8.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
