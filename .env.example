# ===== REQUIRED =====

# Database (PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@host:5432/boomerang

# Auth - MUST be a random 32+ character string in production
JWT_SECRET=change-me-to-a-random-secret-string

# Environment
NODE_ENV=production
PORT=3001

# CORS - comma-separated allowed origins
CORS_ORIGINS=https://www.boomerang.fyi,https://boomerang.fyi

# ===== EMAIL (Resend) =====
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=Boomerang <noreply@boomerang.fyi>

# ===== PAYMENTS (Stripe) =====
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ===== IMAGE UPLOAD (Cloudinary) =====
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===== PUSH NOTIFICATIONS (VAPID) =====
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@boomerang.fyi
